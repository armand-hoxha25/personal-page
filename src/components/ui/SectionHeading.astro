---
interface Props {
  label: string;
  title: string;
}

const { label, title } = Astro.props;
---

<div class="mb-12 text-center">
  <span class="inline-block font-mono text-m text-accent mb-3 tracking-wider uppercase">
    {label}
  </span>
  <h2 class="text-3xl md:text-4xl font-bold text-text-primary">
    {title}
  </h2>
</div>
