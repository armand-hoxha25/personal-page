---
import { personal } from '../data/personal';
---

<section class="relative min-h-screen flex items-center justify-center mesh-gradient grain overflow-hidden">
  <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
    <div class="animate-on-scroll">
      <span class="inline-block font-mono text-sm text-accent mb-6 tracking-wider">
        Hello, I'm
      </span>
    </div>

    <h1 class="animate-on-scroll delay-1 text-5xl md:text-7xl font-extrabold tracking-tight mb-6">
      {personal.name}
    </h1>

    <div class="animate-on-scroll delay-2 h-10 mb-8 overflow-hidden">
      <div class="rotating-text flex flex-col items-center">
        {personal.roles.map((role) => (
          <span class="block text-xl md:text-2xl text-accent-light font-medium h-10 leading-10">
            {role}
          </span>
        ))}
      </div>
    </div>

    <p class="animate-on-scroll delay-3 text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
      {personal.tagline}
    </p>

    <div class="animate-on-scroll delay-4 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#projects"
        class="inline-flex items-center gap-2 px-8 py-3 bg-accent hover:bg-accent-light text-white font-medium rounded-lg transition-all duration-200 hover:shadow-[0_0_24px_rgba(99,102,241,0.3)]"
      >
        View My Work
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-8 py-3 border border-white/10 hover:border-accent/50 text-text-primary font-medium rounded-lg transition-all duration-200 hover:bg-white/5"
      >
        Get In Touch
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>

<style>
  @keyframes rotate-text {
    0% { transform: translateY(0); }
    30% { transform: translateY(0); }
    33.33% { transform: translateY(-33.33%); }
    63.33% { transform: translateY(-33.33%); }
    66.66% { transform: translateY(-66.66%); }
    96.66% { transform: translateY(-66.66%); }
    100% { transform: translateY(0); }
  }

  .rotating-text {
    animation: rotate-text 9s ease-in-out infinite;
  }
</style>
