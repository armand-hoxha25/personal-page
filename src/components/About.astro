---
import SectionHeading from './ui/SectionHeading.astro';
import { personal } from '../data/personal';
---

<section id="about" class="py-24 bg-bg-secondary/50">
  <div class="mx-auto max-w-6xl px-6">

    <div class="grid md:grid-cols-5 gap-12 items-center">
      <!-- Photo placeholder -->
      <div class="md:col-span-2 animate-on-scroll">
        <div class="relative mx-auto w-64 h-64 md:w-full md:h-80 rounded-2xl overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-accent/20 to-accent-secondary/20 flex items-center justify-center">
            <span class="text-6xl font-bold text-accent/30 font-mono">AH</span>
          </div>
          <div class="absolute inset-0 border border-white/10 rounded-2xl"></div>
        </div>
      </div>

      <!-- Bio text -->
      <div class="md:col-span-3 space-y-5">
        <p class="animate-on-scroll text-text-secondary leading-relaxed text-lg">
          I'm a <span class="text-text-primary font-medium">Senior Machine Learning Engineer</span> currently building
          agentic AI systems and production ML infrastructure at
          <span class="text-text-primary font-medium">Extra Space Storage</span>, where I architect LangGraph-based agents,
          RAG pipelines, and a distributed pricing engine serving 4,000+ facilities.
        </p>
        <p class="animate-on-scroll delay-1 text-text-secondary leading-relaxed text-lg">
          Before that, I spent 6 years as a <span class="text-text-primary font-medium">Senior Research Biomedical Engineer</span> at
          the <span class="text-text-primary font-medium">Kessler Foundation</span>, building real-time
          clinical biosignal pipelines (EEG, fNIRS, MRI) and publishing 15+ peer-reviewed papers. I've also built clinical data portals at
          <span class="text-text-primary font-medium">Neuromuscular Dynamics</span> and IoT systems at the
          <span class="text-text-primary font-medium">Motor Development Lab at USC</span>.
        </p>
        <p class="animate-on-scroll delay-2 text-text-secondary leading-relaxed text-lg">
          Outside of work: <span class="text-accent">3D printing enthusiast, indie game developer on Itch.io, and on a mission to visit every U.S. National Park</span>.
        </p>
      </div>
    </div>

    <!-- Stats row -->
    <div class="mt-16 grid grid-cols-3 gap-6">
      {personal.stats.map((stat, i) => (
        <div class={`animate-on-scroll delay-${i + 1} text-center p-6 rounded-xl glass`}>
          <div class="text-3xl md:text-4xl font-bold text-accent mb-1">{stat.value}</div>
          <div class="text-sm text-text-secondary font-mono uppercase tracking-wider">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
