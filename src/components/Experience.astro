---
import SectionHeading from './ui/SectionHeading.astro';
import { experiences } from '../data/experience';
---

<section id="experience" class="py-24 bg-bg-secondary/50">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading label="Experience" title="Where I've Worked" />

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-4 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-0.5 bg-white/10"></div>

      <div class="space-y-12">
        {experiences.map((exp, i) => (
          <div class={`animate-on-scroll delay-${i + 1} relative flex flex-col md:flex-row gap-8 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
            <!-- Timeline dot -->
            <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-accent border-2 border-bg-primary z-10 mt-2"></div>

            <!-- Content card -->
            <div class={`ml-10 md:ml-0 md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:mr-auto md:pr-8' : 'md:ml-auto md:pl-8'}`}>
              <div class="glass rounded-xl p-6">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-4">
                  <div>
                    <h3 class="text-lg font-bold text-text-primary">{exp.role}</h3>
                    <p class="text-accent font-medium">{exp.company}</p>
                  </div>
                  <span class="text-sm font-mono text-text-secondary whitespace-nowrap">{exp.period}</span>
                </div>

                <ul class="space-y-2 mb-4">
                  {exp.description.map((item) => (
                    <li class="text-sm text-text-secondary leading-relaxed flex gap-2">
                      <span class="text-accent mt-1 shrink-0">▸</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>

                <div class="flex flex-wrap gap-2">
                  {exp.tags.map((tag) => (
                    <span class="inline-block px-2 py-0.5 text-xs font-mono text-accent-secondary bg-accent-secondary/10 rounded-full border border-accent-secondary/20">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
